{
  "info": {
    "_postman_id": "f944cd04-cb00-44d7-ad6e-b529b3998264",
    "name": "User",
    "description": "# User API\nEndpoints for managing the authenticated user's profile, balance, and transactions.\n\n**Base URL:** `http://localhost:3000/v1`  \n**Authentication:** Bearer token — use the `{{session}}` environment variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "52767931",
    "_collection_link": "https://go.postman.co/collection/52767931-f944cd04-cb00-44d7-ad6e-b529b3998264?source=collection_link"
  },
  "item": [
    {
      "name": "Get Profile",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "x-refresh-token",
            "value": "{{refresh}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "http://{{host}}/v1/user/me",
          "protocol": "http",
          "host": [
            "{{host}}"
          ],
          "path": [
            "v1",
            "user",
            "me"
          ]
        },
        "description": "Returns the profile information of the currently authenticated user."
      },
      "response": []
    },
    {
      "name": "Get Balance",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "x-refresh-token",
            "value": "{{refresh}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "http://{{host}}/v1/user/me/balance",
          "protocol": "http",
          "host": [
            "{{host}}"
          ],
          "path": [
            "v1",
            "user",
            "me",
            "balance"
          ]
        },
        "description": "Returns the current balance of the authenticated user's account."
      },
      "response": []
    },
    {
      "name": "Get Transactions",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "x-refresh-token",
            "value": "{{refresh}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "http://{{host}}/v1/user/me/transactions?page=1&limit=20",
          "protocol": "http",
          "host": [
            "{{host}}"
          ],
          "path": [
            "v1",
            "user",
            "me",
            "transactions"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "20"
            }
          ]
        },
        "description": "Returns a list of all transactions associated with the authenticated user."
      },
      "response": []
    },
    {
      "name": "Create Transactions",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "x-refresh-token",
            "value": "{{refresh}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"type\": \"deposit\",\n    \"amount\": 100000\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://{{host}}/v1/user/me/transactions",
          "protocol": "http",
          "host": [
            "{{host}}"
          ],
          "path": [
            "v1",
            "user",
            "me",
            "transactions"
          ]
        },
        "description": "Creates a new transaction for the authenticated user. Provide transaction details in the request body."
      },
      "response": []
    },
    {
      "name": "Update Profile",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "x-refresh-token",
            "value": "{{refresh}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"username\": \"David\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://{{host}}/v1/user/me",
          "protocol": "http",
          "host": [
            "{{host}}"
          ],
          "path": [
            "v1",
            "user",
            "me"
          ]
        },
        "description": "Updates the profile information of the authenticated user. Provide the fields to update in the request body."
