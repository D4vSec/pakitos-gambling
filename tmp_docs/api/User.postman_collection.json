    {
      "name": "Delete Profile",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "x-refresh-token",
            "value": "{{refresh}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"type\": \"deposit\",\n    \"amount\": 100\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://{{host}}/v1/user/me",
          "protocol": "http",
          "host": [
            "{{host}}"
          ],
          "path": [
            "v1",
            "user",
            "me"
          ]
        },
        "description": "Permanently deletes the authenticated user's account. This action is irreversible."
      },
      "response": []
    }
  ],
